# Credenciales de Supabase — copia este archivo a .env y completa los valores.
# Ambos se obtienen en: Supabase Dashboard → Project Settings → API
#
# ⚠️ Aquí SOLO va la anon key (pública, protegida por RLS).
#    La service_role key NUNCA debe estar en la app ni en este repositorio.

EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
